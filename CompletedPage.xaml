<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoMaui_Listview.CompletedPage"
             BackgroundColor="#F3F3F5"
             Title="Completed">

    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Grid.Row="0" Padding="16,18,16,0" Spacing="8">
            <Label Text="Completed"
                   FontSize="36"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#C6C6C6" />
            <BoxView HeightRequest="1" BackgroundColor="#DCDCE0" />
        </VerticalStackLayout>

        <ListView x:Name="CompletedListView"
                  Grid.Row="1"
                  Margin="16,10,16,12"
                  HasUnevenRows="True"
                  SeparatorVisibility="None"
                  BackgroundColor="Transparent"
                  ItemTapped="OnItemTapped">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Border Margin="0,0,0,10"
                                Padding="10,8"
                                BackgroundColor="White"
                                Stroke="#D7D7DC"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Label Text="{Binding ItemName}"
                                       FontSize="16"
                                       VerticalOptions="Center"
                                       VerticalTextAlignment="Center"
                                       LineBreakMode="TailTruncation" />

                                <Button Grid.Column="1"
                                        Text="Del"
                                        WidthRequest="54"
                                        HeightRequest="34"
                                        CornerRadius="8"
                                        Padding="0"
                                        FontSize="12"
                                        BackgroundColor="#F7E8EA"
                                        TextColor="#9E4A53"
                                        ClassId="{Binding ItemId}"
                                        Clicked="OnDeleteClicked" />
                            </Grid>
                        </Border>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</ContentPage>
