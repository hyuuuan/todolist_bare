<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoMaui_Listview.CompletedPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource AppSurface}"
             Title="Completed">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F9FCFF" Offset="0.0" />
            <GradientStop Color="#EAF6EF" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto,*" Padding="20,20,20,18">
        <Border Grid.Row="0" Style="{StaticResource AppCardBorderStyle}" Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="2">
                <Label Grid.Row="0"
                       Grid.Column="0"
                       Text="Completed"
                       Style="{StaticResource PageHeadingStyle}" />

                <Label Grid.Row="1"
                       Grid.Column="0"
                       Text="Your finished tasks stay here for quick review."
                       Style="{StaticResource PageSubheadingStyle}" />

                <Border Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="1"
                        Padding="14,10"
                        BackgroundColor="{StaticResource AppSuccessSoft}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 14"
                        HorizontalOptions="End"
                        VerticalOptions="Center">
                    <VerticalStackLayout Spacing="0">
                        <Label HorizontalOptions="Center"
                               Text="{Binding Source={x:Reference CompletedListView}, Path=ItemsSource.Count}"
                               FontFamily="OpenSansSemibold"
                               FontSize="22"
                               TextColor="{StaticResource AppSuccess}" />
                        <Label HorizontalOptions="Center"
                               Text="done"
                               FontFamily="OpenSansRegular"
                               FontSize="11"
                               TextColor="{StaticResource AppTextSecondary}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource AppCardBorderStyle}">
            <ListView x:Name="CompletedListView"
                      HasUnevenRows="True"
                      SeparatorVisibility="None"
                      BackgroundColor="Transparent"
                      ItemTapped="OnItemTapped"
                      Margin="0,4,0,0">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <Border Margin="0,0,0,12"
                                    Padding="12"
                                    BackgroundColor="#FCFFFD"
                                    Stroke="{StaticResource AppCardBorder}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 14">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      RowDefinitions="Auto,Auto"
                                      ColumnSpacing="8"
                                      RowSpacing="4">
                                    <Border Grid.Row="0"
                                            Grid.RowSpan="2"
                                            Grid.Column="0"
                                            WidthRequest="8"
                                            HeightRequest="44"
                                            VerticalOptions="Center"
                                            BackgroundColor="{StaticResource AppSuccessSoft}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 4" />

                                    <Label Grid.Row="0"
                                           Grid.Column="1"
                                           Text="{Binding ItemName}"
                                           FontFamily="OpenSansSemibold"
                                           FontSize="16"
                                           TextColor="{StaticResource AppTextPrimary}"
                                           LineBreakMode="TailTruncation" />

                                    <Button Grid.Row="0"
                                            Grid.Column="2"
                                            Text="Delete"
                                            WidthRequest="68"
                                            HeightRequest="32"
                                            CornerRadius="10"
                                            Padding="0"
                                            FontFamily="OpenSansSemibold"
                                            FontSize="11"
                                            BackgroundColor="{StaticResource AppDangerSoft}"
                                            TextColor="{StaticResource AppDanger}"
                                            ClassId="{Binding ItemId}"
                                            Clicked="OnDeleteClicked" />

                                    <Label Grid.Row="1"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding ItemDescription}"
                                           FontFamily="OpenSansRegular"
                                           FontSize="13"
                                           TextColor="{StaticResource AppTextSecondary}"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding ItemDescription}" Value="">
                                                <Setter Property="Text" Value="Completed with no extra notes" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Grid>
                            </Border>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</ContentPage>
