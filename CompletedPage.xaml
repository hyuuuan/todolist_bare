<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoMaui_Listview.CompletedPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource AppSurface}"
             Title="Completed">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{StaticResource AppSurface}" Offset="0.0" />
            <GradientStop Color="{StaticResource AppSurfaceAlt}" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto,*" Padding="20,20,20,18">
        <Border Grid.Row="0" Style="{StaticResource AppCardBorderStyle}" Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="2">
                <Label Grid.Row="0"
                       Grid.Column="0"
                       Text="Completed"
                       Style="{StaticResource PageHeadingStyle}" />

                <Label Grid.Row="1"
                       Grid.Column="0"
                       Text="Finished tasks stay here so you can review output and progress."
                       Style="{StaticResource PageSubheadingStyle}" />

                <Border Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="1"
                        Style="{StaticResource PillBadgeBorderStyle}"
                        BackgroundColor="{StaticResource AppSuccessSoft}"
                        Stroke="{StaticResource AppSuccessSoftBorder}"
                        HorizontalOptions="End"
                        VerticalOptions="Center">
                    <VerticalStackLayout Spacing="0">
                        <Label HorizontalOptions="Center"
                               Text="{Binding Source={x:Reference CompletedListView}, Path=ItemsSource.Count}"
                               FontFamily="OpenSansSemibold"
                               FontSize="22"
                               TextColor="{StaticResource AppSuccess}" />
                        <Label HorizontalOptions="Center"
                               Text="done"
                               FontFamily="OpenSansRegular"
                               FontSize="11"
                               TextColor="{StaticResource AppTextSecondary}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <CollectionView x:Name="CompletedListView"
                            BackgroundColor="Transparent"
                            SelectionMode="Single"
                            SelectionChanged="OnItemTapped">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12"
                                Padding="14"
                                BackgroundColor="{StaticResource AppCard}"
                                Stroke="{StaticResource AppCardBorder}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 14">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  RowDefinitions="Auto,Auto"
                                  ColumnSpacing="10"
                                  RowSpacing="4">
                                <Border Grid.Row="0"
                                        Grid.RowSpan="2"
                                        Grid.Column="0"
                                        WidthRequest="8"
                                        HeightRequest="44"
                                        VerticalOptions="Center"
                                        BackgroundColor="{StaticResource AppSuccessSoft}"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 4" />

                                <Label Grid.Row="0"
                                       Grid.Column="1"
                                       Text="{Binding ItemName}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="16"
                                       TextColor="{StaticResource AppTextPrimary}"
                                       LineBreakMode="TailTruncation" />

                                <Button Grid.Row="0"
                                        Grid.RowSpan="2"
                                        Grid.Column="2"
                                        Text="Delete"
                                        WidthRequest="72"
                                        HeightRequest="34"
                                        CornerRadius="10"
                                        Padding="0"
                                        FontFamily="OpenSansSemibold"
                                        FontSize="12"
                                        BackgroundColor="{StaticResource AppDangerSoft}"
                                        TextColor="{StaticResource AppDanger}"
                                        VerticalOptions="Center"
                                        ClassId="{Binding ItemId}"
                                        Clicked="OnDeleteClicked" />

                                <Label Grid.Row="1"
                                       Grid.Column="1"
                                       Text="{Binding ItemDescription}"
                                       FontFamily="OpenSansRegular"
                                       FontSize="13"
                                       TextColor="{StaticResource AppTextSecondary}"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding ItemDescription}" Value="">
                                            <Setter Property="Text" Value="Completed with no additional notes" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border Margin="26,70,26,0"
                    Padding="22,18"
                    BackgroundColor="{StaticResource AppCard}"
                    Stroke="{StaticResource AppCardBorder}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    VerticalOptions="Center"
                    IsVisible="False"
                    InputTransparent="True">
                <Border.Triggers>
                    <DataTrigger TargetType="Border"
                                 Binding="{Binding Source={x:Reference CompletedListView}, Path=ItemsSource.Count}"
                                 Value="0">
                        <Setter Property="IsVisible" Value="True" />
                    </DataTrigger>
                </Border.Triggers>

                <VerticalStackLayout Spacing="6">
                    <Label Text="No completed tasks yet"
                           FontFamily="OpenSansSemibold"
                           FontSize="18"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource AppTextPrimary}" />
                    <Label Text="When you finish tasks, they will appear here for quick review."
                           FontFamily="OpenSansRegular"
                           FontSize="13"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource AppTextSecondary}" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
