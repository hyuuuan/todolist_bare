<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ToDoMaui_Listview"
             x:Class="ToDoMaui_Listview.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="AppSurface">#F3F6FB</Color>
            <Color x:Key="AppSurfaceAlt">#E7EEF8</Color>
            <Color x:Key="AppCard">#FFFFFF</Color>
            <Color x:Key="AppCardBorder">#D4DEEC</Color>
            <Color x:Key="AppInputSurface">#F9FBFF</Color>
            <Color x:Key="AppInputBorder">#CCD8EA</Color>

            <Color x:Key="AppTextPrimary">#13233A</Color>
            <Color x:Key="AppTextSecondary">#63748D</Color>
            <Color x:Key="AppTextMuted">#8493A7</Color>

            <Color x:Key="AppBrand">#295FB7</Color>
            <Color x:Key="AppBrandDark">#1D4A94</Color>
            <Color x:Key="AppBrandSoft">#E8F0FF</Color>
            <Color x:Key="AppBrandSoftBorder">#C3D6FF</Color>

            <Color x:Key="AppSuccess">#2E7D52</Color>
            <Color x:Key="AppSuccessSoft">#E7F4EC</Color>
            <Color x:Key="AppSuccessSoftBorder">#C5E5D1</Color>

            <Color x:Key="AppDanger">#BC3A4D</Color>
            <Color x:Key="AppDangerSoft">#FDECEF</Color>
            <Color x:Key="AppDangerSoftBorder">#F7C9D1</Color>

            <Color x:Key="AppNeutralSoft">#EDF2F8</Color>
            <Color x:Key="AppNeutralBorder">#D4DEEC</Color>

            <Style x:Key="PageHeadingStyle" TargetType="Label">
                <Setter Property="FontFamily" Value="OpenSansSemibold" />
                <Setter Property="FontSize" Value="30" />
                <Setter Property="TextColor" Value="{StaticResource AppTextPrimary}" />
                <Setter Property="LineBreakMode" Value="TailTruncation" />
            </Style>

            <Style x:Key="PageSubheadingStyle" TargetType="Label">
                <Setter Property="FontFamily" Value="OpenSansRegular" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource AppTextSecondary}" />
                <Setter Property="LineBreakMode" Value="WordWrap" />
            </Style>

            <Style x:Key="SectionLabelStyle" TargetType="Label">
                <Setter Property="FontFamily" Value="OpenSansSemibold" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="CharacterSpacing" Value="1.2" />
                <Setter Property="TextColor" Value="{StaticResource AppTextMuted}" />
            </Style>

            <Style x:Key="AppCardBorderStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource AppCard}" />
                <Setter Property="Stroke" Value="{StaticResource AppCardBorder}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 18" />
                <Setter Property="Padding" Value="16" />
            </Style>

            <Style x:Key="InputBorderStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource AppInputSurface}" />
                <Setter Property="Stroke" Value="{StaticResource AppInputBorder}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 14" />
                <Setter Property="Padding" Value="14,0" />
            </Style>

            <Style x:Key="InputEntryStyle" TargetType="Entry">
                <Setter Property="TextColor" Value="{StaticResource AppTextPrimary}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource AppTextMuted}" />
                <Setter Property="FontFamily" Value="OpenSansRegular" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="HeightRequest" Value="50" />
                <Setter Property="ClearButtonVisibility" Value="WhileEditing" />
            </Style>

            <Style x:Key="InputEditorStyle" TargetType="Editor">
                <Setter Property="TextColor" Value="{StaticResource AppTextPrimary}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource AppTextMuted}" />
                <Setter Property="FontFamily" Value="OpenSansRegular" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="AutoSize" Value="TextChanges" />
                <Setter Property="HeightRequest" Value="120" />
            </Style>

            <Style x:Key="ActionButtonBaseStyle" TargetType="Button">
                <Setter Property="HeightRequest" Value="50" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="14,10" />
                <Setter Property="FontFamily" Value="OpenSansSemibold" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonBaseStyle}">
                <Setter Property="BackgroundColor" Value="{StaticResource AppBrand}" />
                <Setter Property="TextColor" Value="White" />
            </Style>

            <Style x:Key="SecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonBaseStyle}">
                <Setter Property="BackgroundColor" Value="{StaticResource AppNeutralSoft}" />
                <Setter Property="TextColor" Value="{StaticResource AppTextPrimary}" />
            </Style>

            <Style x:Key="SuccessActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonBaseStyle}">
                <Setter Property="BackgroundColor" Value="{StaticResource AppSuccessSoft}" />
                <Setter Property="TextColor" Value="{StaticResource AppSuccess}" />
            </Style>

            <Style x:Key="DangerActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonBaseStyle}">
                <Setter Property="BackgroundColor" Value="{StaticResource AppDangerSoft}" />
                <Setter Property="TextColor" Value="{StaticResource AppDanger}" />
            </Style>

            <Style x:Key="PillBadgeBorderStyle" TargetType="Border">
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 12" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
