<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoMaui_Listview.SignInPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource AppSurface}"
             Title="Sign In">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#EEF3FF" Offset="0.0" />
            <GradientStop Color="#F7FAFF" Offset="0.55" />
            <GradientStop Color="#E9F3FF" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="24,54,24,28" Spacing="16">
            <VerticalStackLayout Spacing="2">
                <Label Text="TaskFlow"
                       FontFamily="OpenSansSemibold"
                       FontSize="34"
                       TextColor="{StaticResource AppTextPrimary}" />
                <Label Text="Sign in to continue planning your day."
                       Style="{StaticResource PageSubheadingStyle}" />
            </VerticalStackLayout>

            <Border Style="{StaticResource AppCardBorderStyle}"
                    StrokeThickness="0"
                    BackgroundColor="{StaticResource AppBrandSoft}">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" VerticalOptions="Center">
                    <Border WidthRequest="54"
                            HeightRequest="54"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 27"
                            BackgroundColor="White">
                        <Image Source="dotnet_bot.png"
                               Margin="8"
                               Aspect="AspectFit" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                        <Label Text="Welcome back"
                               FontFamily="OpenSansSemibold"
                               FontSize="16"
                               TextColor="{StaticResource AppBrandDark}" />
                        <Label Text="Your tasks are synced to this account."
                               FontFamily="OpenSansRegular"
                               FontSize="12"
                               TextColor="{StaticResource AppTextSecondary}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Border Style="{StaticResource AppCardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Email"
                           FontFamily="OpenSansSemibold"
                           FontSize="13"
                           TextColor="{StaticResource AppTextPrimary}" />
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry x:Name="EmailEntry"
                               Placeholder="name@example.com"
                               Style="{StaticResource InputEntryStyle}"
                               Keyboard="Email"
                               ReturnType="Next" />
                    </Border>

                    <Label Text="Password"
                           FontFamily="OpenSansSemibold"
                           FontSize="13"
                           TextColor="{StaticResource AppTextPrimary}" />
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry x:Name="PasswordEntry"
                               Placeholder="Enter your password"
                               IsPassword="True"
                               Style="{StaticResource InputEntryStyle}"
                               Keyboard="Text"
                               ReturnType="Done" />
                    </Border>

                    <Button Text="Sign in"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Margin="0,4,0,0"
                            Clicked="OnSignInClicked" />

                    <Button Text="Create account"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Clicked="OnGoToSignUpClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
