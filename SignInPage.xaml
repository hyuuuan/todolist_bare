<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoMaui_Listview.SignInPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource AppSurface}"
             Title="Sign In">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0.9,1">
            <GradientStop Color="{StaticResource AppSurface}" Offset="0.0" />
            <GradientStop Color="{StaticResource AppSurfaceAlt}" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="24,56,24,30" Spacing="16">
            <VerticalStackLayout Spacing="4">
                <Label Text="TASKFLOW"
                       Style="{StaticResource SectionLabelStyle}" />
                <Label Text="Welcome back"
                       Style="{StaticResource PageHeadingStyle}"
                       FontSize="34" />
                <Label Text="Sign in to review priorities and keep your day moving."
                       Style="{StaticResource PageSubheadingStyle}" />
            </VerticalStackLayout>

            <Border Style="{StaticResource AppCardBorderStyle}"
                    BackgroundColor="{StaticResource AppBrandSoft}"
                    Stroke="{StaticResource AppBrandSoftBorder}"
                    Padding="14">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="12"
                      VerticalOptions="Center">
                    <Border WidthRequest="52"
                            HeightRequest="52"
                            BackgroundColor="White"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 26"
                            Padding="8">
                        <Image Source="dotnet_bot.png"
                               Aspect="AspectFit" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1"
                                         VerticalOptions="Center"
                                         Spacing="2">
                        <Label Text="Account synced"
                               FontFamily="OpenSansSemibold"
                               FontSize="15"
                               TextColor="{StaticResource AppBrandDark}" />
                        <Label Text="Your active and completed tasks stay connected to this account."
                               FontFamily="OpenSansRegular"
                               FontSize="12"
                               TextColor="{StaticResource AppTextSecondary}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Border Style="{StaticResource AppCardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Email"
                           FontFamily="OpenSansSemibold"
                           FontSize="13"
                           TextColor="{StaticResource AppTextPrimary}" />
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry x:Name="EmailEntry"
                               Placeholder="name@example.com"
                               Style="{StaticResource InputEntryStyle}"
                               Keyboard="Email"
                               ReturnType="Next" />
                    </Border>

                    <Label Text="Password"
                           FontFamily="OpenSansSemibold"
                           FontSize="13"
                           TextColor="{StaticResource AppTextPrimary}" />
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry x:Name="PasswordEntry"
                               Placeholder="Enter your password"
                               IsPassword="True"
                               Style="{StaticResource InputEntryStyle}"
                               Keyboard="Text"
                               ReturnType="Done" />
                    </Border>

                    <Button Text="Sign in"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Margin="0,4,0,0"
                            Clicked="OnSignInClicked" />

                    <Button Text="Create account"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Clicked="OnGoToSignUpClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
