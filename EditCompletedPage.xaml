<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoMaui_Listview.EditCompletedPage"
             BackgroundColor="{StaticResource AppSurface}"
             Title="Edit Completed">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{StaticResource AppSurface}" Offset="0.0" />
            <GradientStop Color="{StaticResource AppSurfaceAlt}" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="20,18,20,24" Spacing="14">
            <Border Style="{StaticResource AppCardBorderStyle}">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Edit Completed Task"
                           Style="{StaticResource PageHeadingStyle}"
                           FontSize="24" />
                    <Label Text="Refine details, move back to active, or remove permanently."
                           Style="{StaticResource PageSubheadingStyle}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource AppCardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Task Title"
                           FontFamily="OpenSansSemibold"
                           FontSize="13"
                           TextColor="{StaticResource AppTextPrimary}" />
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry x:Name="TitleEntry"
                               Placeholder="Task title"
                               Style="{StaticResource InputEntryStyle}"
                               Keyboard="Text"
                               ReturnType="Next" />
                    </Border>

                    <Label Text="Details"
                           FontFamily="OpenSansSemibold"
                           FontSize="13"
                           TextColor="{StaticResource AppTextPrimary}" />
                    <Border Style="{StaticResource InputBorderStyle}" Padding="14,8">
                        <Editor x:Name="DetailsEditor"
                                Placeholder="Notes"
                                Style="{StaticResource InputEditorStyle}"
                                Keyboard="Text" />
                    </Border>

                    <Button Text="Update"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Margin="0,4,0,0"
                            Clicked="OnUpdateClicked" />

                    <Button Text="Move to Active"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Clicked="OnIncompleteClicked" />

                    <Button Text="Delete Task"
                            Style="{StaticResource DangerActionButtonStyle}"
                            Clicked="OnDeleteClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
