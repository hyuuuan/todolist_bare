<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoMaui_Listview.SignUpPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource AppSurface}"
             Title="Sign Up">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#EFF4FF" Offset="0.0" />
            <GradientStop Color="#FAFCFF" Offset="0.55" />
            <GradientStop Color="#EAF4FF" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="24,42,24,28" Spacing="16">
            <VerticalStackLayout Spacing="2">
                <Label Text="Create Account"
                       FontFamily="OpenSansSemibold"
                       FontSize="31"
                       TextColor="{StaticResource AppTextPrimary}" />
                <Label Text="Start organizing your tasks in one clean workspace."
                       Style="{StaticResource PageSubheadingStyle}" />
            </VerticalStackLayout>

            <Border Style="{StaticResource AppCardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="User Name"
                           FontFamily="OpenSansSemibold"
                           FontSize="13"
                           TextColor="{StaticResource AppTextPrimary}" />
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry x:Name="UserNameEntry"
                               Placeholder="What should we call you?"
                               Style="{StaticResource InputEntryStyle}"
                               Keyboard="Text"
                               ReturnType="Next" />
                    </Border>

                    <Label Text="Email"
                           FontFamily="OpenSansSemibold"
                           FontSize="13"
                           TextColor="{StaticResource AppTextPrimary}" />
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry x:Name="EmailEntry"
                               Placeholder="name@example.com"
                               Style="{StaticResource InputEntryStyle}"
                               Keyboard="Email"
                               ReturnType="Next" />
                    </Border>

                    <Label Text="Password"
                           FontFamily="OpenSansSemibold"
                           FontSize="13"
                           TextColor="{StaticResource AppTextPrimary}" />
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry x:Name="PasswordEntry"
                               Placeholder="Set a password"
                               IsPassword="True"
                               Style="{StaticResource InputEntryStyle}"
                               Keyboard="Text"
                               ReturnType="Next" />
                    </Border>

                    <Label Text="Confirm Password"
                           FontFamily="OpenSansSemibold"
                           FontSize="13"
                           TextColor="{StaticResource AppTextPrimary}" />
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry x:Name="ConfirmPasswordEntry"
                               Placeholder="Re-enter password"
                               IsPassword="True"
                               Style="{StaticResource InputEntryStyle}"
                               Keyboard="Text"
                               ReturnType="Done" />
                    </Border>

                    <Button Text="Create account"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Margin="0,4,0,0"
                            Clicked="OnSignUpClicked" />

                    <Button Text="Back to sign in"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Clicked="OnGoToSignInClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
