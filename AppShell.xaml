<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ToDoMaui_Listview.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:ToDoMaui_Listview"
    Shell.FlyoutBehavior="Disabled"
    Shell.BackgroundColor="{StaticResource AppSurface}"
    Shell.TabBarBackgroundColor="{StaticResource AppCard}"
    Shell.TabBarForegroundColor="{StaticResource AppBrand}"
    Shell.TabBarTitleColor="{StaticResource AppBrand}"
    Shell.TabBarUnselectedColor="{StaticResource AppTextSecondary}"
    Shell.NavBarHasShadow="False"
    Title="To Do">

    <TabBar>
        <Tab Title="Tasks" Route="todo-tab">
            <ShellContent
                Title="Tasks"
                Route="todo"
                ContentTemplate="{DataTemplate local:ToDoPage}" />
        </Tab>

        <Tab Title="Completed" Route="completed-tab">
            <ShellContent
                Title="Completed"
                Route="completed"
                ContentTemplate="{DataTemplate local:CompletedPage}" />
        </Tab>

        <Tab Title="Profile" Route="profile-tab">
            <ShellContent
                Title="Profile"
                Route="profile"
                ContentTemplate="{DataTemplate local:ProfilePage}" />
        </Tab>
    </TabBar>
</Shell>
