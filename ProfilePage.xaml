<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoMaui_Listview.ProfilePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource AppSurface}"
             Title="Profile">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F8FBFF" Offset="0.0" />
            <GradientStop Color="#EDF1FF" Offset="0.65" />
            <GradientStop Color="#F4F9F8" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="20,20,20,28" Spacing="14">
            <Border Style="{StaticResource AppCardBorderStyle}">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                    <Border WidthRequest="76"
                            HeightRequest="76"
                            StrokeThickness="0"
                            BackgroundColor="{StaticResource AppBrandSoft}"
                            StrokeShape="RoundRectangle 38"
                            VerticalOptions="Center">
                        <Image Source="dotnet_bot.png"
                               Aspect="AspectFill"
                               Margin="6" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <Label Text="Account"
                               FontFamily="OpenSansRegular"
                               FontSize="12"
                               TextColor="{StaticResource AppTextSecondary}" />
                        <Label x:Name="NameLabel"
                               Text="User"
                               FontFamily="OpenSansSemibold"
                               FontSize="22"
                               TextColor="{StaticResource AppTextPrimary}"
                               LineBreakMode="TailTruncation" />
                        <Label x:Name="EmailLabel"
                               Text="user@example.com"
                               FontFamily="OpenSansRegular"
                               FontSize="13"
                               TextColor="{StaticResource AppTextSecondary}"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Border Grid.Column="0"
                        Style="{StaticResource AppCardBorderStyle}"
                        BackgroundColor="#F8FAFF">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Open"
                               FontFamily="OpenSansRegular"
                               FontSize="12"
                               TextColor="{StaticResource AppTextSecondary}" />
                        <Label x:Name="PendingCountLabel"
                               Text="0"
                               FontFamily="OpenSansSemibold"
                               FontSize="30"
                               TextColor="{StaticResource AppBrandDark}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource AppCardBorderStyle}"
                        BackgroundColor="#F6FCF9">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Completed"
                               FontFamily="OpenSansRegular"
                               FontSize="12"
                               TextColor="{StaticResource AppTextSecondary}" />
                        <Label x:Name="CompletedCountLabel"
                               Text="0"
                               FontFamily="OpenSansSemibold"
                               FontSize="30"
                               TextColor="{StaticResource AppSuccess}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border Style="{StaticResource AppCardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Session"
                           Style="{StaticResource PageHeadingStyle}"
                           FontSize="20" />
                    <Label Text="Use sign out if you are on a shared device to keep your task list private."
                           Style="{StaticResource PageSubheadingStyle}" />
                    <Button Text="Sign out"
                            Style="{StaticResource DangerActionButtonStyle}"
                            Margin="0,4,0,0"
                            Clicked="OnSignOutClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
