<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoMaui_Listview.ProfilePage"
             BackgroundColor="#F3F3F5"
             Title="Profile">

    <Grid RowDefinitions="Auto,*" Padding="18,14,18,18">
        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <Label Text="Profile"
                   FontSize="36"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#565862" />
            <BoxView HeightRequest="1" BackgroundColor="#DCDCE0" />
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="14"
                             WidthRequest="280">
            <Border BackgroundColor="#D0D0D4"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8"
                    HeightRequest="180"
                    WidthRequest="220"
                    HorizontalOptions="Center">
                <Image Source="dotnet_bot.png"
                       Aspect="AspectFit"
                       Opacity="0.7"
                       Margin="10" />
            </Border>

            <Label x:Name="NameLabel"
                   Text="User"
                   HorizontalOptions="Center"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#4F4F4F" />

            <Label x:Name="EmailLabel"
                   Text="user@example.com"
                   HorizontalOptions="Center"
                   FontSize="14"
                   TextColor="#808080" />

            <Button Text="Sign out"
                    Margin="0,6,0,0"
                    HeightRequest="50"
                    CornerRadius="10"
                    FontAttributes="Bold"
                    BackgroundColor="#8C8C8C"
                    TextColor="White"
                    Clicked="OnSignOutClicked" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
