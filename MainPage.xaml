<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoMaui_Listview.MainPage"
             BackgroundColor="{StaticResource AppSurface}"
             Title="To Do">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{StaticResource AppSurface}" Offset="0.0" />
            <GradientStop Color="{StaticResource AppSurfaceAlt}" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Grid.Row="0"
                             Padding="20,20,20,14"
                             Spacing="12">
            <Border Style="{StaticResource AppCardBorderStyle}">
                <VerticalStackLayout Spacing="4">
                    <Label Text="QUICK CAPTURE"
                           Style="{StaticResource SectionLabelStyle}" />
                    <Label Text="Plan Your Next Move"
                           Style="{StaticResource PageHeadingStyle}"
                           FontSize="28" />
                    <Label Text="Add a task, edit details fast, and keep execution tidy."
                           Style="{StaticResource PageSubheadingStyle}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource AppCardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Task Title"
                           FontFamily="OpenSansSemibold"
                           FontSize="13"
                           TextColor="{StaticResource AppTextPrimary}" />
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry x:Name="titleEntry"
                               Placeholder="Task title"
                               Style="{StaticResource InputEntryStyle}"
                               Keyboard="Text"
                               ReturnType="Next"
                               MaxLength="50" />
                    </Border>

                    <Label Text="Details"
                           FontFamily="OpenSansSemibold"
                           FontSize="13"
                           TextColor="{StaticResource AppTextPrimary}" />
                    <Border Style="{StaticResource InputBorderStyle}" Padding="14,8">
                        <Editor x:Name="detailsEditor"
                                Placeholder="Details (optional)"
                                Style="{StaticResource InputEditorStyle}"
                                MaxLength="240"
                                Keyboard="Text"
                                HeightRequest="86" />
                    </Border>

                    <Grid ColumnSpacing="10" ColumnDefinitions="*,*,*">
                        <Button x:Name="addBtn"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                IsVisible="True"
                                Text="Add Task"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Clicked="AddToDoItem" />

                        <Button x:Name="editBtn"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                IsVisible="False"
                                Text="Save Changes"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Clicked="EditToDoItem" />

                        <Button x:Name="cancelBtn"
                                Grid.Column="2"
                                IsVisible="False"
                                Text="Cancel"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Clicked="CancelEdit" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <Grid Grid.Row="1"
              RowDefinitions="Auto,*"
              Padding="20,0,20,0">
            <Label Grid.Row="0"
                   Text="ACTIVE ITEMS"
                   Style="{StaticResource SectionLabelStyle}"
                   Margin="0,0,0,8" />

            <CollectionView x:Name="todoLV"
                            Grid.Row="1"
                            BackgroundColor="Transparent"
                            SelectionMode="Single"
                            SelectionChanged="TodoLV_OnItemSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12"
                                Padding="14"
                                BackgroundColor="{StaticResource AppCard}"
                                Stroke="{StaticResource AppCardBorder}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 14">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  RowDefinitions="Auto,Auto"
                                  ColumnSpacing="10"
                                  RowSpacing="4">
                                <Border Grid.Column="0"
                                        Grid.Row="0"
                                        Grid.RowSpan="2"
                                        WidthRequest="6"
                                        HeightRequest="42"
                                        StrokeThickness="0"
                                        BackgroundColor="{StaticResource AppBrandSoft}"
                                        StrokeShape="RoundRectangle 3"
                                        VerticalOptions="Center" />

                                <Label Grid.Row="0"
                                       Grid.Column="1"
                                       Text="{Binding title}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="16"
                                       TextColor="{StaticResource AppTextPrimary}"
                                       LineBreakMode="TailTruncation" />

                                <Label Grid.Row="1"
                                       Grid.Column="1"
                                       Text="{Binding detail}"
                                       FontFamily="OpenSansRegular"
                                       FontSize="13"
                                       TextColor="{StaticResource AppTextSecondary}"
                                       LineBreakMode="TailTruncation" />

                                <Button Grid.Row="0"
                                        Grid.RowSpan="2"
                                        Grid.Column="2"
                                        Text="Delete"
                                        WidthRequest="72"
                                        HeightRequest="34"
                                        CornerRadius="10"
                                        Padding="0"
                                        FontFamily="OpenSansSemibold"
                                        FontSize="12"
                                        BackgroundColor="{StaticResource AppDangerSoft}"
                                        TextColor="{StaticResource AppDanger}"
                                        VerticalOptions="Center"
                                        ClassId="{Binding id}"
                                        Clicked="DeleteToDoItem" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>
