<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoMaui_Listview.MainPage"
             BackgroundColor="{StaticResource AppBg}"
             Title="To Do">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Input Panel ── -->
        <VerticalStackLayout Grid.Row="0"
                             Padding="16,20,16,16"
                             Spacing="12"
                             BackgroundColor="{StaticResource InputPanelBg}">

            <Label Text="NEW TASK"
                   FontSize="11" FontAttributes="Bold" CharacterSpacing="1.5"
                   TextColor="{StaticResource TextOnDark}" Opacity="0.55"/>

            <!-- Title -->
            <Border BackgroundColor="{StaticResource InputBg}"
                    Stroke="{StaticResource InputBorder}"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="1"
                    Padding="12,0">
                <Entry x:Name="titleEntry"
                       Placeholder="Title"
                       PlaceholderColor="{StaticResource TextSecondary}"
                       TextColor="{StaticResource TextPrimary}"
                       BackgroundColor="Transparent"
                       Keyboard="Text" ReturnType="Next" MaxLength="50"
                       HeightRequest="44"/>
            </Border>

            <!-- Details -->
            <Border BackgroundColor="{StaticResource InputBg}"
                    Stroke="{StaticResource InputBorder}"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="1"
                    Padding="12,4">
                <Editor x:Name="detailsEditor"
                        Placeholder="Details"
                        PlaceholderColor="{StaticResource TextSecondary}"
                        TextColor="{StaticResource TextPrimary}"
                        BackgroundColor="Transparent"
                        MaxLength="240" Keyboard="Text"
                        HeightRequest="72"
                        AutoSize="TextChanges"/>
            </Border>

            <!-- Action Buttons -->
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="addBtn"
                        Grid.Column="0" Grid.ColumnSpan="3"
                        IsVisible="True"
                        Text="＋  Add Task"
                        TextColor="White"
                        BackgroundColor="{StaticResource AccentPrimary}"
                        CornerRadius="10" HeightRequest="46"
                        FontAttributes="Bold" FontSize="15"
                        Clicked="AddToDoItem"/>

                <Button x:Name="editBtn"
                        Grid.Column="0" Grid.ColumnSpan="2"
                        IsVisible="False"
                        Text="Save Changes"
                        TextColor="White"
                        BackgroundColor="{StaticResource AccentEdit}"
                        CornerRadius="10" HeightRequest="46"
                        FontAttributes="Bold" FontSize="15"
                        Clicked="EditToDoItem"/>

                <Button x:Name="cancelBtn"
                        Grid.Column="2"
                        IsVisible="False"
                        Text="Cancel"
                        TextColor="White"
                        BackgroundColor="{StaticResource AccentDanger}"
                        CornerRadius="10" HeightRequest="46"
                        FontAttributes="Bold" FontSize="14"
                        Clicked="CancelEdit"/>
            </Grid>
        </VerticalStackLayout>

        <!-- ── List ── -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*">

            <Label Grid.Row="0"
                   Text="MY TASKS"
                   FontSize="11" FontAttributes="Bold" CharacterSpacing="1.5"
                   TextColor="{StaticResource TextSecondary}"
                   Margin="16,14,16,6"/>

            <ListView x:Name="todoLV"
                      Grid.Row="1"
                      HorizontalOptions="Fill" VerticalOptions="FillAndExpand"
                      HasUnevenRows="True"
                      SeparatorVisibility="None"
                      BackgroundColor="{StaticResource AppBg}"
                      ItemSelected="TodoLV_OnItemSelected"
                      ItemTapped="todoLV_ItemTapped">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <Border BackgroundColor="{StaticResource CardBg}"
                                    Stroke="{StaticResource CardBorder}"
                                    StrokeShape="RoundRectangle 12"
                                    StrokeThickness="1"
                                    Margin="16,5"
                                    Padding="14,12">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="{Binding title}"
                                           FontSize="16" FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"
                                           LineBreakMode="TailTruncation"
                                           VerticalOptions="Center"/>

                                    <Label Grid.Row="1" Grid.Column="0"
                                           Text="{Binding detail}"
                                           FontSize="13"
                                           TextColor="{StaticResource TextSecondary}"
                                           LineBreakMode="WordWrap"
                                           VerticalOptions="Center"
                                           Margin="0,3,0,0"/>

                                    <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                            Text="Delete"
                                            BackgroundColor="{StaticResource AccentDanger}"
                                            TextColor="White"
                                            FontSize="13" FontAttributes="Bold"
                                            CornerRadius="8"
                                            WidthRequest="72" HeightRequest="38"
                                            Padding="0"
                                            VerticalOptions="Center"
                                            ClassId="{Binding id}"
                                            Clicked="DeleteToDoItem"/>
                                </Grid>
                            </Border>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

    </Grid>
</ContentPage>
